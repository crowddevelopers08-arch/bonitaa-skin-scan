generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Scan {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  problem   String
  imageData String
  createdAt DateTime @default(now())
}
